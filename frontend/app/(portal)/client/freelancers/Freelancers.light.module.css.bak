/* AI-HINT: Light theme overrides for Client Freelancers page. */

/* AI-HINT: Light theme styles for the Freelancers page. */

.page {
  background-color: #ffffff;
}

.title {
  color: #23272f;
}

.subtitle {
  color: #333333;
}

.controlsSection {
  background-color: #f5f7fa;
  border: 1px solid #e0e0e0;
}

.emptyState {
  background-color: #f5f7fa;
  border: 1px dashed #e0e0e0;
}

.emptyState h3 {
  color: #23272f;
}

.emptyState p {
  color: #333333;
}

.paginationInfo {
  color: #333333;
}

.skeletonCard {
  background-color: #f5f7fa;
  border: 1px solid #e0e0e0;
}