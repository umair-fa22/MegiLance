/* Dark Theme - Freelancer Earnings */
.container { background: #0f172a; }
.title { color: #f8fafc; }
.subtitle { color: #94a3b8; }
.statCard { background: #1e293b; border: 1px solid #334155; }
.statValue { color: #f8fafc; }
.statLabel { color: #94a3b8; }
.periodBtn { background: #334155; color: #cbd5e1; }
.periodBtn:hover { background: #334155; }
.periodBtnActive { background: #4573df !important; color: #fff !important; }
.section { background: #1e293b; border: 1px solid #334155; }
.sectionTitle { color: #f8fafc; }
.chartBar { background: #4573df; }
.chartBarLabel { color: #94a3b8; }
.chartBarValue { color: #f8fafc; }
.breakdownItem { background: #1e293b; }
.breakdownLabel { color: #cbd5e1; }
.breakdownValue { color: #f8fafc; }
.tableWrapper { background: #1e293b; border: 1px solid #334155; }
.th { background: #1e293b; color: #94a3b8; border-bottom: 1px solid #334155; }
.td { color: #cbd5e1; border-bottom: 1px solid #334155; }
.tr:hover { background: #1e293b; }
.emptyState { background: #1e293b; color: #94a3b8; }
.emptyState h3 { color: #f8fafc; }
