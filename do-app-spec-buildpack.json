{
  "name": "megilance",
  "services": [
    {
      "name": "backend",
      "github": {
        "repo": "umair-fa22/MegiLance",
        "branch": "main",
        "deploy_on_push": true
      },
      "dockerfile_path": "backend/Dockerfile",
      "instance_size_slug": "basic-s",
      "instance_count": 1,
      "http_port": 8000
    },
    {
      "name": "ai-service",
      "github": {
        "repo": "umair-fa22/MegiLance",
        "branch": "main",
        "deploy_on_push": true
      },
      "dockerfile_path": "ai/Dockerfile",
      "instance_size_slug": "basic-s",
      "instance_count": 1,
      "http_port": 8001
    },
    {
      "name": "frontend",
      "github": {
        "repo": "umair-fa22/MegiLance",
        "branch": "main",
        "deploy_on_push": true
      },
      "build_command": "npm install --legacy-peer-deps --no-save lightningcss-linux-x64-gnu@1.32.0 @tailwindcss/oxide-linux-x64-gnu@4.2.4 && npm run build",
      "envs": [
        {
          "key": "NODE_ENV",
          "value": "production",
          "scope": "RUN_AND_BUILD_TIME"
        }
      ],
      "instance_size_slug": "basic-s",
      "instance_count": 1,
      "http_port": 3000,
      "source_dir": "frontend"
    }
  ],
  "domains": [
    {
      "domain": "megilance.site",
      "type": "PRIMARY",
      "zone": "megilance.site"
    },
    {
      "domain": "www.megilance.site",
      "type": "ALIAS",
      "zone": "megilance.site"
    },
    {
      "domain": "api.megilance.site",
      "type": "ALIAS",
      "zone": "megilance.site"
    }
  ],
  "region": "blr",
  "ingress": {
    "rules": [
      {
        "match": {
          "path": {
            "prefix": "/api"
          }
        },
        "component": {
          "name": "backend",
          "preserve_path_prefix": true
        }
      },
      {
        "match": {
          "path": {
            "prefix": "/ai-api"
          }
        },
        "component": {
          "name": "ai-service",
          "preserve_path_prefix": true
        }
      },
      {
        "match": {
          "path": {
            "prefix": "/"
          }
        },
        "component": {
          "name": "frontend"
        }
      }
    ]
  },
  "features": [
    "buildpack-stack=ubuntu-22"
  ]
}
